NADO_ENV=mainnet
NADO_WS_BASE=wss://gateway.prod.nado.xyz/v1/subscribe
NADO_REST_BASE=https://gateway.prod.nado.xyz/v1
NADO_ARCHIVE_BASE=https://archive.prod.nado.xyz/v1
NADO_PRODUCT_ID=
NADO_PRICE_SCALE=1000000000000000000
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS
SUBACCOUNT_NAME=default
SYMBOL=BTC-PERP
ORDER_SIZE=0.001
LEVERAGE=1
EXECUTION_STYLE=maker
COMMISSION_MAKER_BPS=1
COMMISSION_TAKER_BPS=3.5
SHORT_WINDOW=4
LONG_WINDOW=12
MIN_EDGE_BPS=0.1
STOP_LOSS_PCT=0.22
TAKE_PROFIT_PCT=0.40
TRAILING_PCT=0.18
COOLDOWN_TICKS=10
USE_BOOK_PRICES=true
PING_INTERVAL_SECONDS=20
RECONNECT_DELAY_SECONDS=5
WS_OPEN_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_TO_CONSOLE=true
LOG_TICKER_EVERY=10
READ_ONLY=true
DRY_RUN=true
ENABLE_REAL_FEE_SYNC=true
MIN_WALLET_BALANCE_USD=5
PROTECT_NET_POSITIVE_ONLY=false
