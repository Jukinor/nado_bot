# ── Nado API endpoints ────────────────────────────────────────────────────────
NADO_ENV=mainnet
NADO_WS_BASE=wss://gateway.prod.nado.xyz/v1/subscribe
NADO_REST_BASE=https://gateway.prod.nado.xyz/v1
NADO_ARCHIVE_BASE=https://archive.prod.nado.xyz/v1
NADO_TRIGGER_BASE=https://trigger.prod.nado.xyz/v1
NADO_STREAM_TYPE=best_bid_offer
NADO_PRODUCT_ID=1
NADO_PRICE_SCALE=1000000000000000000
NADO_VOLUME_30D_USD=0

# ── Wallet ────────────────────────────────────────────────────────────────────
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS
SUBACCOUNT_NAME=default

# ── Trading params ────────────────────────────────────────────────────────────
SYMBOL=BTC-PERP
ORDER_SIZE=0.001
LEVERAGE=1
EXECUTION_STYLE=maker

# ── Commission (bps) ──────────────────────────────────────────────────────────
COMMISSION_MAKER_BPS=1
COMMISSION_TAKER_BPS=3.5

# ── Order fill & TP/SL ───────────────────────────────────────────────────────
ORDER_FILL_TIMEOUT_SEC=90
ENABLE_TRIGGER_TP_SL=true

# ── Strategy ─────────────────────────────────────────────────────────────────
SHORT_WINDOW=8
LONG_WINDOW=24
MIN_EDGE_BPS=2
STOP_LOSS_PCT=0.22
TAKE_PROFIT_PCT=0.40
TRAILING_PCT=0.18
COOLDOWN_TICKS=10
USE_BOOK_PRICES=true

# ── Safety ────────────────────────────────────────────────────────────────────
READ_ONLY=true
DRY_RUN=true
MIN_WALLET_BALANCE_USD=5
ENABLE_REAL_FEE_SYNC=true
PROTECT_NET_POSITIVE_ONLY=false

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_TO_CONSOLE=true
LOG_TICKER_EVERY=1

# ── Connection ────────────────────────────────────────────────────────────────
PING_INTERVAL_SECONDS=20
RECONNECT_DELAY_SECONDS=5
WS_OPEN_TIMEOUT_SECONDS=20
